generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  OUT_OF_STOCK
  ARCHIVED
}

enum StockReservationStatus {
  ACTIVE
  EXPIRED
  CONVERTED
  CANCELLED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum DeliveryMethod {
  NATIONAL_SHIPPING
  LOCAL_DELIVERY
  LOCAL_PICKUP
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
  PAYMENT_FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
  CHARGEBACK
  IN_REVIEW
}

enum InvoiceStatus {
  NOT_REQUESTED
  REQUESTED
  ISSUED
  REJECTED
}

enum InventoryMovementType {
  INITIAL_STOCK
  MANUAL_ADJUSTMENT
  SALE
  RESERVATION
  RESERVATION_RELEASE
  RETURN
}

enum HomeSectionType {
  HERO
  BANNER
  PRODUCT_CAROUSEL
  CATEGORY_GRID
  COLLECTION_GRID
  PROMO_STRIP
  TEXT_BLOCK
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)

  accounts Account[]
  sessions Session[]

  stockReservations  StockReservation[]
  inventoryMovements InventoryMovement[]
  carts              Cart[]
  orders             Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  imageUrl    String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  indexable      Boolean @default(true)
  ogImage        String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Audience {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audiences")
}

model Collection {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  imageUrl    String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  indexable      Boolean @default(true)
  ogImage        String?

  products ProductCollection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("collections")
}

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  shortDescription String?       @db.Text
  description      String?       @db.Text
  status           ProductStatus @default(DRAFT)

  basePrice     Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)

  isFeatured Boolean @default(false)
  isNew      Boolean @default(false)

  categoryId String
  audienceId String

  category Category @relation(fields: [categoryId], references: [id])
  audience Audience @relation(fields: [audienceId], references: [id])

  variants    ProductVariant[]
  images      ProductImage[]
  collections ProductCollection[]

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  canonicalUrl   String?
  indexable      Boolean @default(true)
  ogTitle        String?
  ogDescription  String?
  ogImage        String?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
  @@index([audienceId])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id        String @id @default(cuid())
  productId String
  sku       String @unique
  name      String

  color String?
  size  String?

  priceOverride Decimal? @db.Decimal(10, 2)

  stockTotal     Int @default(0)
  stockAvailable Int @default(0)
  stockReserved  Int @default(0)

  isActive Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  stockReservations  StockReservation[]
  inventoryMovements InventoryMovement[]
  cartItems          CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model ProductCollection {
  productId    String
  collectionId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("product_collections")
}

model StockReservation {
  id               String                 @id @default(cuid())
  userId           String?
  sessionId        String?
  productVariantId String
  quantity         Int
  status           StockReservationStatus @default(ACTIVE)
  expiresAt        DateTime
  orderId          String?

  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([productVariantId])
  @@index([status])
  @@index([expiresAt])
  @@map("stock_reservations")
}

model InventoryMovement {
  id               String                @id @default(cuid())
  productVariantId String
  userId           String?
  type             InventoryMovementType
  quantity         Int
  note             String?               @db.Text

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([productVariantId])
  @@index([userId])
  @@index([type])
  @@map("inventory_movements")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?
  sessionId String?
  status    CartStatus @default(ACTIVE)

  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id               String @id @default(cuid())
  cartId           String
  productVariantId String
  quantity         Int    @default(1)

  cart           Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productVariantId])
  @@index([cartId])
  @@index([productVariantId])
  @@map("cart_items")
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique
  userId      String?
  sessionId   String?

  status        OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus @default(PENDING)

  paymentProvider  String?
  paymentReference String?

  customerName  String
  customerEmail String
  customerPhone String

  deliveryMethod   DeliveryMethod
  shippingAddress  String? @db.Text
  postalCode       String?
  city             String?
  state            String?
  addressReference String? @db.Text

  invoiceStatus    InvoiceStatus @default(NOT_REQUESTED)
  fiscalRfc        String?
  fiscalName       String?
  fiscalPostalCode String?
  fiscalRegime     String?
  fiscalCfdiUse    String?
  fiscalEmail      String?

  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  notes String? @db.Text

  user     User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payments PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderItem {
  id               String @id @default(cuid())
  orderId          String
  productId        String
  productVariantId String

  productName String
  sku         String
  unitPrice   Decimal @db.Decimal(10, 2)
  quantity    Int
  lineTotal   Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

model PaymentTransaction {
  id                String  @id @default(cuid())
  orderId           String
  provider          String
  providerOrderId   String?
  providerCaptureId String?
  status            String
  amount            Decimal @db.Decimal(10, 2)
  currency          String
  payerEmail        String?
  rawResponse       String? @db.Text

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("payment_transactions")
}

model HomeSection {
  id         String          @id @default(cuid())
  type       HomeSectionType
  title      String?
  subtitle   String?
  imageUrl   String?
  buttonText String?
  buttonUrl  String?
  data       Json?
  sortOrder  Int             @default(0)
  isActive   Boolean         @default(true)
  startsAt   DateTime?
  endsAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@map("home_sections")
}

model StoreSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("store_settings")
}
