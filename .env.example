# Base de datos MySQL / MariaDB
DATABASE_URL="mysql://usuario:password@127.0.0.1:3306/importadora_dev"

# URLs de la app
APP_URL="http://localhost:3000"
# URL publica usada para SEO (sitemap, canonical, Open Graph). En produccion: dominio real.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth (NextAuth v5)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google login (opcional, pendiente)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Pasarela de pago activa por defecto: paypal | stripe
PAYMENT_PROVIDER="paypal"
PAYMENT_CURRENCY="MXN"

# PayPal (sandbox | live)
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_CURRENCY="MXN"

# Stripe (claves de test pk_test_/sk_test_; en produccion usar restricted key rk_)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# Secreto opcional para proteger el job de expiracion de reservas
# (POST /api/jobs/expire-reservations con Authorization: Bearer <secret>)
CRON_SECRET=""

# Seed admin (opcional; por defecto admin@importadora.local / Admin123!)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
